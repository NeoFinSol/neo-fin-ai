# NeoFin AI Backend - Production Multi-Stage Dockerfile
# Optimized for security, size, and layer caching

# ==============================================================================
# Stage 1: Build - Install dependencies
# ==============================================================================
FROM python:3.11-slim AS build

WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV VIRTUAL_ENV=/app/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Install build-time dependencies
# libpq-dev: PostgreSQL headers (required by psycopg2/asyncpg)
# build-essential: C compiler for building psycopg2
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libpq-dev \
        build-essential \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Copy only requirements first (leverage Docker layer caching)
# This layer is cached until requirements.txt changes
COPY requirements.txt .

# Create virtual environment and install production dependencies
# --no-cache-dir reduces image size by not storing pip cache
RUN python -m venv $VIRTUAL_ENV \
    && $VIRTUAL_ENV/bin/pip install --upgrade pip setuptools wheel \
    && $VIRTUAL_ENV/bin/pip install --no-cache-dir -r requirements.txt

# ==============================================================================
# Stage 2: Runtime - Minimal production image
# ==============================================================================
FROM python:3.11-slim AS runtime

WORKDIR /app

# Set environment variables
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV VIRTUAL_ENV=/app/venv
ENV PATH="$VIRTUAL_ENV/bin:$PATH"

# Install minimal runtime dependencies
# libpq5: PostgreSQL client library (required by psycopg2/asyncpg at runtime)
# curl: health checks
# ca-certificates: HTTPS requests (GigaChat/Qwen APIs)
# tesseract-ocr: OCR engine (required by pytesseract for scanned PDFs)
# poppler-utils: PDF rendering (required by pdf2image for OCR preprocessing)
# libgl1: OpenGL library (required by opencv-python for camelot table extraction)
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        libpq5 \
        curl \
        ca-certificates \
        tesseract-ocr \
        poppler-utils \
        libgl1 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Copy virtual environment from build stage
COPY --from=build /app/venv /app/venv

# Copy only production code (exclude tests, .git, dev files)
COPY src ./src
COPY alembic.ini .
COPY migrations ./migrations
COPY entrypoint.sh ./entrypoint.sh

# Create non-root user for security (run as unprivileged user)
RUN useradd --create-home --shell /bin/bash appuser \
    && chmod +x /app/entrypoint.sh \
    && chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Health check: verify backend is responding
# Runs every 30s, times out after 10s, allows 10s startup, 3 retries
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:8000/system/health || exit 1

EXPOSE 8000

# Default command: run application (no migrations)
# Migrations should be run separately via init container or docker-compose
CMD ["./venv/bin/uvicorn", "src.app:app", "--host", "0.0.0.0", "--port", "8000"]
