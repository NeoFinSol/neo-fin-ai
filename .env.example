# =============================================================================
# NeoFin AI Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Security - API Authentication
# -----------------------------------------------------------------------------
# Generate a secure API key for production use.
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# For local development, you can set DEV_MODE=1 to disable authentication.
# WARNING: Never use DEV_MODE=1 in production!
API_KEY=your-secure-api-key-here
# DEV_MODE=1  # Uncomment to disable authentication for local development

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# Controls the minimum level of messages to log.
# Use DEBUG for development, INFO or WARNING for production.
LOG_LEVEL=INFO

# LOG_FORMAT: text, json (default: text)
# - text: Human-readable logs (development)
# - json: Structured JSON logs (production, for ELK/CloudWatch/etc.)
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Resilience & Retry Configuration
# -----------------------------------------------------------------------------
# RETRY_COUNT: Number of retry attempts for transient failures (default: 3)
# Used for AI calls, OCR operations, external APIs.
RETRY_COUNT=3

# RETRY_BACKOFF: Multiplier for exponential backoff (default: 2.0)
# Delay sequence: 1s, 2s, 4s, 8s, ...
RETRY_BACKOFF=2.0

# RETRY_INITIAL_DELAY: Initial delay in seconds before first retry (default: 1.0)
RETRY_INITIAL_DELAY=1.0

# AI_TIMEOUT: Timeout for AI service calls in seconds (default: 120)
AI_TIMEOUT=120

# AI_RETRY_COUNT: Number of retries for AI calls (default: 2)
# Set to 0 to disable retry for AI calls.
AI_RETRY_COUNT=2

# AI_RETRY_BACKOFF: Backoff multiplier for AI retries (default: 2.0)
AI_RETRY_BACKOFF=2.0

# AI_CIRCUIT_BREAKER_THRESHOLD: Number of consecutive AI failures before
# opening circuit breaker (default: 5)
# When opened, AI calls are temporarily blocked to prevent cascading failures.
AI_CIRCUIT_BREAKER_THRESHOLD=5

# AI_CIRCUIT_BREAKER_TIMEOUT: Seconds to wait before testing AI recovery
# after circuit breaker opens (default: 120 = 2 minutes)
AI_CIRCUIT_BREAKER_TIMEOUT=120

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL credentials (used by docker-compose.yml)
#
# IMPORTANT: These values are REQUIRED - no defaults in docker-compose.yml
# For local development, you can copy docker-compose.override.yml.example to
# docker-compose.override.yml which provides safe defaults.
#
# Generate secure password: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password-here
POSTGRES_DB=neofin

# Database connection URLs (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Note: Uses shell-style variable interpolation (supported by python-dotenv)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db_test:5432/neofin_test

# For testing without .env, set TESTING=1 to bypass DATABASE_URL validation
# TESTING=1

# -----------------------------------------------------------------------------
# Production Deployment (optional)
# -----------------------------------------------------------------------------
# SSL certificate paths (for HTTPS, optional)
# Uncomment and set paths when using SSL in production
# SSL_CERT_PATH=/etc/nginx/certs/cert.pem
# SSL_KEY_PATH=/etc/nginx/certs/key.pem

# -----------------------------------------------------------------------------
# Database Connection Pool Settings (optional, safe defaults used)
# -----------------------------------------------------------------------------
# These settings control the async database connection pool.
# Adjust based on your deployment size and PostgreSQL max_connections.
#
# DB_POOL_SIZE: Number of connections to maintain in the pool (default: 5)
#   - Small deployments: 2-5
#   - Medium deployments: 5-10
#   - Large deployments: 10-20 (ensure PostgreSQL can handle total connections)
#   WARNING: pool_size + max_overflow should not exceed PostgreSQL max_connections
#
# DB_MAX_OVERFLOW: Max additional connections beyond pool_size (default: 10)
#   - Set to 0 for fixed pool size
#   - Higher values allow burst traffic but consume more DB resources
#
# DB_POOL_TIMEOUT: Seconds to wait for available connection (default: 30)
#   - Increase if you frequently get "pool timeout" errors
#
# DB_POOL_RECYCLE: Seconds after which to recycle connections (default: 3600)
#   - Prevents stale connections; set lower if DB restarts frequently
#
# DB_POOL_PRE_PING: Enable connection health check before use (default: true)
#   - Set to "false" for slight performance gain (not recommended)
#
# Example for small production deployment:
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600
# DB_POOL_PRE_PING=true

# -----------------------------------------------------------------------------
# AI Services Configuration
# -----------------------------------------------------------------------------

# GigaChat (Sberbank) - Priority AI provider
GIGACHAT_CLIENT_ID=your-client-id
GIGACHAT_CLIENT_SECRET=your-client-secret
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

# GigaChat SSL Verification
# Set to "false" ONLY for development with self-signed certificates
# WARNING: Disabling SSL verification exposes you to MITM attacks!
GIGACHAT_SSL_VERIFY=true

# Qwen (Alibaba) - Backup AI provider
QWEN_API_KEY=your-api-key
QWEN_API_URL=https://api.qwen.ai/v1

# Local LLM (Ollama) - Offline mode
LLM_URL=http://localhost:11434/api/generate
LLM_MODEL=llama3

# -----------------------------------------------------------------------------
# CORS Configuration (CRITICAL FOR SECURITY)
# -----------------------------------------------------------------------------
# CORS: разрешённые источники (разделены запятой)
# ⚠️  В продакшене НЕ используйте '*' — явно перечисляйте домены:
#   CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
#
# Если переменная не задана, по умолчанию разрешается только localhost (для разработки)
# Для локальной разработки (localhost origins безопасны):
CORS_ALLOW_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With,X-API-Key
CORS_ALLOW_CREDENTIALS=false

# -----------------------------------------------------------------------------
# Rate Limiting (optional, default: 100 requests per minute)
# -----------------------------------------------------------------------------
# Format: <count>/<period> where period is second, minute, hour, day
# Examples: 100/minute, 1000/hour, 10/second
RATE_LIMIT=100/minute

# -----------------------------------------------------------------------------
# LLM Extraction (экспериментальная функция)
# -----------------------------------------------------------------------------
# Включает LLM-based извлечение финансовых метрик из PDF вместо regex/camelot.
# По умолчанию отключено — pipeline работает как раньше.
# Требует настроенного AI-провайдера (GigaChat, HuggingFace или Ollama).
LLM_EXTRACTION_ENABLED=false

# Максимальный размер одного чанка текста, отправляемого в LLM (символы).
# Допустимый диапазон: 1000–50000. По умолчанию: 12000.
LLM_CHUNK_SIZE=12000

# Максимальное количество чанков на один PDF-документ.
# Приоритет отдаётся первым чанкам (финансовые таблицы обычно в начале).
# Допустимый диапазон: 1–20. По умолчанию: 5.
LLM_MAX_CHUNKS=5

# Максимальный суммарный объём текста (символы ≈ токены × 4) на один PDF.
# При превышении LLM-extraction пропускается, используется fallback (regex).
# Допустимый диапазон: 1000–200000. По умолчанию: 50000.
LLM_TOKEN_BUDGET=50000
