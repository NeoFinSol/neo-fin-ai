# =============================================================================
# NeoFin AI Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control!

# -----------------------------------------------------------------------------
# Security - API Authentication
# -----------------------------------------------------------------------------
# Generate a secure API key for production use.
# Python: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 
# For local development, you can set DEV_MODE=1 to disable authentication.
# WARNING: Never use DEV_MODE=1 in production!
API_KEY=your-secure-api-key-here
# DEV_MODE=1  # Uncomment to disable authentication for local development

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL credentials (used by docker-compose.yml)
# 
# IMPORTANT: These values are REQUIRED - no defaults in docker-compose.yml
# For local development, you can copy docker-compose.override.yml.example to
# docker-compose.override.yml which provides safe defaults.
#
# Generate secure password: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-db-password-here
POSTGRES_DB=neofin

# Database connection URLs (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Note: Uses shell-style variable interpolation (supported by python-dotenv)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db_test:5432/neofin_test

# For testing without .env, set TESTING=1 to bypass DATABASE_URL validation
# TESTING=1

# -----------------------------------------------------------------------------
# AI Services Configuration
# -----------------------------------------------------------------------------

# GigaChat (Sberbank) - Priority AI provider
GIGACHAT_CLIENT_ID=your-client-id
GIGACHAT_CLIENT_SECRET=your-client-secret
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_CHAT_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

# GigaChat SSL Verification
# Set to "false" ONLY for development with self-signed certificates
# WARNING: Disabling SSL verification exposes you to MITM attacks!
GIGACHAT_SSL_VERIFY=true

# Qwen (Alibaba) - Backup AI provider
QWEN_API_KEY=your-api-key
QWEN_API_URL=https://api.qwen.ai/v1

# Local LLM (Ollama) - Offline mode
LLM_URL=http://localhost:11434/api/generate
LLM_MODEL=llama3

# -----------------------------------------------------------------------------
# CORS Configuration (CRITICAL FOR SECURITY)
# -----------------------------------------------------------------------------
# CORS: разрешённые источники (разделены запятой)
# ⚠️  В продакшене НЕ используйте '*' — явно перечисляйте домены:
#   CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
#
# Если переменная не задана, по умолчанию разрешается только localhost (для разработки)
# Для локальной разработки (localhost origins безопасны):
CORS_ALLOW_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=false

# -----------------------------------------------------------------------------
# Rate Limiting (optional, default: 100 requests per minute)
# -----------------------------------------------------------------------------
# Format: <count>/<period> where period is second, minute, hour, day
# Examples: 100/minute, 1000/hour, 10/second
RATE_LIMIT=100/minute

# -----------------------------------------------------------------------------
# Logging Configuration (optional)
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json, text
LOG_FORMAT=text
