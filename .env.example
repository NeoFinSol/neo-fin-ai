# Qwen AI API configuration
QWEN_API_KEY=...
QWEN_API_URL=...

# Local LLM configuration (Ollama)
LLM_URL=http://localhost:11434/api/generate
LLM_MODEL=llama3

# Database configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neofin
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/neofin_test

# CORS configuration (optional, defaults are secure)
CORS_ALLOW_ORIGINS=http://localhost,http://localhost:80,http://127.0.0.1,http://127.0.0.1:80
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=false
