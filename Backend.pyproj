<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{12345678-1234-1234-1234-123456789012}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>src\app.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>Backend</Name>
    <RootNamespace>neo-fin-ai</RootNamespace>
    <IsWindowsApplication>False</IsWindowsApplication>
    <LegacyInterpreterPath />
    <InterpreterId>MSBuild|env1|$(MSBuildProjectFullPath)</InterpreterId>
    <TestFramework>Pytest</TestFramework>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <Optimize>false</Optimize>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <Optimize>true</Optimize>
  </PropertyGroup>
  <ItemGroup>
    <!-- Main Application -->
    <Compile Include="examples\recommendations_examples.py" />
    <Compile Include="init_project.py" />
    <Compile Include="setup.py" />
    <Compile Include="src\analysis\recommendations.py" />
    <Compile Include="src\app.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Controllers -->
    <Compile Include="src\controllers\analyze.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Core -->
    <Compile Include="src\core\agent.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\ai_service.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\auth.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\constants.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\gigachat_agent.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\prompts.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\security.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Database -->
    <Compile Include="src\db\__init__.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\db\crud.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\db\database.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\db\models.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Models -->
    <Compile Include="src\models\requests.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\models\schemas.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\models\settings.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\models\database\project.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\models\database\user.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Routers -->
    <Compile Include="src\routers\analyze.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\routers\pdf_tasks.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\routers\system.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Analysis -->
    <Compile Include="src\analysis\__init__.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\analysis\nlp_analysis.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\analysis\pdf_extractor.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\analysis\ratios.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\analysis\scoring.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Exceptions -->
    <Compile Include="src\exceptions\PdfExtractException.py">
      <SubType>Code</SubType>
    </Compile>
    <!-- Tasks -->
    <Compile Include="src\tasks.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_analysis_ratios_new.py" />
    <Compile Include="tests\test_recommendations.py" />
  </ItemGroup>
  <ItemGroup>
    <!-- Configuration Files -->
    <Content Include=".commit_message.txt" />
    <Content Include=".env.example">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include=".vscode\extensions.json" />
    <Content Include=".vscode\launch.json" />
    <Content Include=".vscode\settings.json" />
    <Content Include="ADDITIONAL_ISSUES_FIX_PLAN.md" />
    <Content Include="AFTER_FIX_CHECKLIST.md" />
    <Content Include="BUILDING.md" />
    <Content Include="BUILD_GUIDE.md" />
    <Content Include="BUILD_README.md" />
    <Content Include="BUILD_README_INDEX.md" />
    <Content Include="COMMIT_SUMMARY.txt" />
    <Content Include="COMPLETE_PROJECT_FIX_SUMMARY.md" />
    <Content Include="COMPLETION_CHECKLIST.md" />
    <Content Include="COMPREHENSIVE_FIX_REPORT.md" />
    <Content Include="CRITICAL_FIXES_REPORT.md" />
    <Content Include="CRITICAL_ISSUES_PLAN.md" />
    <Content Include="docs\RECOMMENDATIONS_MODULE.md" />
    <Content Include="EXAMPLES.md" />
    <Content Include="FINAL_DELIVERY.md" />
    <Content Include="FINAL_REPORT.txt" />
    <Content Include="FINAL_STATUS.md" />
    <Content Include="FINANCIAL_RATIOS_EXPANSION.md" />
    <Content Include="FIXES_SUMMARY.md" />
    <Content Include="FIX_DOCUMENTATION_INDEX.md" />
    <Content Include="GIT_COMMIT_REPORT.md" />
    <Content Include="IMPLEMENTATION_GUIDE_ISSUES_9_13.md" />
    <Content Include="init_project.bat" />
    <Content Include="init_project.ps1" />
    <Content Include="INSTALLATION_SUCCESS.md" />
    <Content Include="MASTER_FIX_INDEX.md" />
    <Content Include="PDFMINER_FIX.md" />
    <Content Include="PROJECT_SETUP_REPORT.md" />
    <Content Include="PYTHON_VERSION_FIX.md" />
    <Content Include="QUICK_FIX_GUIDE.md" />
    <Content Include="QUICK_START.md" />
    <Content Include="RATIOS_EXPANSION_REPORT.md" />
    <Content Include="RATIOS_INTEGRATION_EXAMPLES.md" />
    <Content Include="README.md">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="README_RATIOS_EXPANSION.md" />
    <Content Include="RECOMMENDATIONS_COMPLETION_SUMMARY.md" />
    <Content Include="RECOMMENDATIONS_IMPLEMENTATION.md" />
    <Content Include="RECOMMENDATIONS_QUICKSTART.md" />
    <Content Include="requirements.txt">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="requirements-dev.txt">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="docker-compose.yml">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="docker-compose.override.yml.example">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="Dockerfile">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="alembic.ini">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="entrypoint.sh">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="run.bat">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="run.ps1">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <!-- Documentation -->
    <Content Include="GETTING_STARTED.md">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="DATABASE_SETUP_GUIDE.md">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include="GIGACHAT_SETUP.md">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <!-- Git files -->
    <Content Include="SESSION_COMPLETION_REPORT.md" />
    <Content Include="SETUP_COMPLETE.md" />
    <Content Include="SETUP_DOCUMENTATION_INDEX.md" />
    <Content Include="SETUP_SUMMARY.md" />
    <Content Include="START_HERE.md" />
    <None Include=".gitignore">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include=".flake8">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
    <None Include=".pre-commit-config.yaml">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Folder Include=".vscode\" />
    <Folder Include="examples\" />
    <Folder Include="src" />
    <Folder Include="src\analysis" />
    <Folder Include="src\controllers" />
    <Folder Include="src\core" />
    <Folder Include="src\db" />
    <Folder Include="src\db\models" />
    <Folder Include="src\exceptions" />
    <Folder Include="src\models" />
    <Folder Include="src\models\database" />
    <Folder Include="src\routers" />
    <Folder Include="migrations" />
    <Folder Include="migrations\versions" />
    <Folder Include="scripts" />
    <Folder Include="docs" />
    <Folder Include="tests\" />
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env1\">
      <Id>env1</Id>
      <Version>3.11</Version>
      <Description>env1 (Python 3.11 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
    <Interpreter Include="env1\env2\">
      <Id>env2</Id>
      <Version>3.9</Version>
      <Description>env2 (Python 3.9 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
    <Interpreter Include="env\">
      <Id>env</Id>
      <Version>3.9</Version>
      <Description>env (Python 3.9 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>