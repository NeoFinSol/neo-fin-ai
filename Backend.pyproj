<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{12345678-1234-1234-1234-123456789012}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>src\app.py</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>Backend</Name>
    <RootNamespace>neo-fin-ai</RootNamespace>
    <IsWindowsApplication>False</IsWindowsApplication>
    <LegacyInterpreterPath />
    <InterpreterId>MSBuild|env|$(MSBuildProjectFullPath)</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <Optimize>false</Optimize>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <Optimize>true</Optimize>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="src\app.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\controllers\analyze.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\agent.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\core\prompts.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\db\database.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\models\settings.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\routers\system.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="src\routers\analyze.py">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Content Include=".env.example" />
    <Content Include=".gitignore" />
    <Content Include="README.md" />
    <Content Include="requirements.txt" />
    <Content Include="docker-compose.yml" />
    <Content Include="Dockerfile" />
    <Content Include="entrypoint.sh" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="src" />
    <Folder Include="src\controllers" />
    <Folder Include="src\core" />
    <Folder Include="src\db" />
    <Folder Include="src\models" />
    <Folder Include="src\routers" />
    <Folder Include="migrations" />
    <Folder Include="docs" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>
