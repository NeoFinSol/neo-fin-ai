{
  "enabled": true,
  "name": "Python Lint on Save",
  "description": "Запускает flake8 только для сохранённого файла (не весь проект)",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.py",
      "tests/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "python -m flake8 \"${file}\" --max-line-length=120 --extend-ignore=E203,W503",
    "timeout": 15
  }
}