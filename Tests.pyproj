    <Compile Include="tests\test_analysis_scoring.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_api.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_app.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_auth.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_benchmarks.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_controllers_analyze.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_db_crud.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_db_database.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_db_integration.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_e2e.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_frontend_e2e.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_models_settings.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_nlp_analysis.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_pdf_extractor.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_ratios.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_routers_pdf_tasks.py">
