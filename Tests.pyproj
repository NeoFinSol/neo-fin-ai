<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003" ToolsVersion="4.0">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{11223344-5566-7788-9900-AABBCCDDEEFF}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>pytest.ini</StartupFile>
    <SearchPath>
    </SearchPath>
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>Tests</Name>
    <RootNamespace>neo-fin-ai-tests</RootNamespace>
    <IsWindowsApplication>False</IsWindowsApplication>
    <InterpreterId>MSBuild|env2|$(MSBuildProjectFullPath)</InterpreterId>
    <TestCommand>pytest</TestCommand>
    <TestArguments>-v</TestArguments>
    <TestFramework>Pytest</TestFramework>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <Optimize>false</Optimize>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <Optimize>true</Optimize>
  </PropertyGroup>
  <ItemGroup>
    <!-- Test Files -->
    <Compile Include="tests\conftest.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_agent.py">
      <SubType>Code</SubType>
    </Compile>
    <Compile Include="tests\test_analysis_pdf_extractor.py">
      <SubType>Code</SubType>
