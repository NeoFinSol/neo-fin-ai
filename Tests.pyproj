    </Compile>
    <Compile Include="tests\test_tasks.py">
      <SubType>Code</SubType>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <!-- Test Configuration -->
    <Content Include="pytest.ini">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <Content Include=".coverage">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </Content>
    <None Include=".gitignore">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <Folder Include="tests" />
    <Folder Include="docs" />
    <Folder Include="docs\old_reports" />
    <Folder Include="docs\old_bugs(corrected)" />
    <Folder Include="docs\tasks" />
  </ItemGroup>
  <!-- Reference Backend project -->
  <ItemGroup>
    <ProjectReference Include="Backend.pyproj">
      <Project>{12345678-1234-1234-1234-123456789012}</Project>
      <Name>Backend</Name>
    </ProjectReference>
    <ProjectReference Include="frontend\Frontend.njsproj">
      <Name>Frontend</Name>
      <Project>{87654321-4321-4321-4321-210987654321}</Project>
      <Private>True</Private>
    </ProjectReference>
  </ItemGroup>
  <ItemGroup>
    <Reference Include="Accessibility, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a">
      <Name>Accessibility</Name>
      <AssemblyName>Accessibility.dll</AssemblyName>
      <HintPath>C:\Program Files (x86)\Reference Assemblies\Microsoft\Framework\.NETFramework\v4.7.2\Accessibility.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <Interpreter Include="env2\">
      <Id>env2</Id>
      <Version>3.11</Version>
      <Description>env2 (Python 3.11 (64-bit))</Description>
      <InterpreterPath>Scripts\python.exe</InterpreterPath>
      <WindowsInterpreterPath>Scripts\pythonw.exe</WindowsInterpreterPath>
      <PathEnvironmentVariable>PYTHONPATH</PathEnvironmentVariable>
      <Architecture>X64</Architecture>
    </Interpreter>
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
